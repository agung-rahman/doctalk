    {
      "parameters": {
        "jsCode": "const base64 = $input.first().json.data;\nconst buffer = Buffer.from(base64, 'base64');\nconst zlib = require('zlib');\n\nconst zip = buffer;\nlet text = '';\nlet offset = 0;\n\nwhile (offset < zip.length - 4) {\n  if (zip[offset] === 0x50 && zip[offset+1] === 0x4B && \n      zip[offset+2] === 0x03 && zip[offset+3] === 0x04) {\n    \n    const compression = zip.readUInt16LE(offset + 8);\n    const compressedSize = zip.readUInt32LE(offset + 18);\n    const fileNameLength = zip.readUInt16LE(offset + 26);\n    const extraLength = zip.readUInt16LE(offset + 28);\n    const fileName = zip.slice(offset + 30, offset + 30 + fileNameLength).toString('utf-8');\n    const dataOffset = offset + 30 + fileNameLength + extraLength;\n    const compressedData = zip.slice(dataOffset, dataOffset + compressedSize);\n    \n    if (fileName === 'word/document.xml') {\n      let xmlBuffer;\n      if (compression === 0) {\n        xmlBuffer = compressedData;\n      } else if (compression === 8) {\n        xmlBuffer = zlib.inflateRawSync(compressedData);\n      }\n      \n      if (xmlBuffer) {\n        const xml = xmlBuffer.toString('utf-8');\n        const matches = xml.match(/<w:t(?:\\s[^>]*)?>([^<]*)<\\/w:t>/g) || [];\n        text = matches\n          .map(tag => tag.replace(/<[^>]+>/g, '').trim())\n          .filter(Boolean)\n          .join(' ');\n      }\n      break;\n    }\n    \n    offset = dataOffset + compressedSize;\n  } else {\n    offset++;\n  }\n}\n\nif (!text || text.length < 5) {\n  return [{ json: { content: 'Could not read this Word file. Please convert to PDF and try again.' } }];\n}\n\nreturn [{ json: { content: text } }];"
      },
