    {
      "parameters": {
        "jsCode": "const items = $input.first().json.data;\n\nif (!items || items.length === 0) {\n  return [{ json: { content: 'File Excel kosong atau tidak bisa dibaca.' } }];\n}\n\nconst text = items.map((row, i) => {\n  return `Row ${i + 1}: ` + Object.entries(row)\n    .map(([k, v]) => `${k}: ${v ?? '-'}`)\n    .join(' | ');\n}).join('\\n');\n\nreturn [{ json: { content: text } }];"
      },
