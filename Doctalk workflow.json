    {
      "parameters": {
        "jsCode": "const telegramData = $('HTTP Request').first().json;\nconst updates = telegramData.result;\n\nif (!updates || updates.length === 0) {\n  return [{\n    json: {\n      skip: true, userMessage: '', chatId: '', username: '',\n      messageId: '', hasDocument: false, fileId: '', fileName: '',\n      fileType: '', mimeType: ''\n    }\n  }];\n}\n\nconst latest = updates[0];\nconst msg = latest.message || latest.channel_post;\n\nif (!msg || msg.from?.is_bot) {\n  return [{\n    json: {\n      skip: true, userMessage: '', chatId: '', username: '',\n      messageId: '', hasDocument: false, fileId: '', fileName: '',\n      fileType: '', mimeType: ''\n    }\n  }];\n}\n\n// Skip pesan yang lebih dari 50 detik\nconst msgTime = msg.date * 1000;\nconst now = Date.now();\nif (now - msgTime > 50000) {\n  return [{\n    json: {\n      skip: true, userMessage: '', chatId: '', username: '',\n      messageId: '', hasDocument: false, fileId: '', fileName: '',\n      fileType: '', mimeType: ''\n    }\n  }];\n}\n\nconst chatId = String(msg.chat.id);\nconst username = msg.from?.username || msg.from?.first_name || 'anon';\nconst messageId = String(msg.message_id);\n\n// Deduplication pakai static data\nconst staticData = $getWorkflowStaticData('node');\nconst processedKey = `msg_${messageId}`;\n\nif (staticData[processedKey]) {\n  return [{\n    json: {\n      skip: true, userMessage: '', chatId: '', username: '',\n      messageId: '', hasDocument: false, fileId: '', fileName: '',\n      fileType: '', mimeType: ''\n    }\n  }];\n}\n\n// Simpan messageId dan bersihkan yang sudah expired (10 menit)\nstaticData[processedKey] = Date.now();\nObject.keys(staticData).forEach(key => {\n  if (key.startsWith('msg_') && (Date.now() - staticData[key]) > 600000) {\n    delete staticData[key];\n  }\n});\n\n// Deteksi dokumen (document, photo, audio, video)\nconst doc = msg.document || null;\nconst hasDocument = !!doc;\n\nlet fileId = '';\nlet fileName = '';\nlet fileType = '';\nlet mimeType = '';\n\nif (hasDocument) {\n  fileId = doc.file_id || '';\n  fileName = doc.file_name || 'unknown_file';\n  mimeType = doc.mime_type || '';\n\n  // Deteksi fileType dari extension atau mime_type\n  const extFromName = fileName.split('.').pop().toLowerCase();\n\n  if (mimeType.includes('pdf') || extFromName === 'pdf') {\n    fileType = 'pdf';\n  } else if (\n    mimeType.includes('spreadsheet') ||\n    mimeType.includes('excel') ||\n    ['xlsx', 'xls'].includes(extFromName)\n  ) {\n    fileType = 'xlsx';\n  } else if (\n    mimeType.includes('csv') ||\n    extFromName === 'csv'\n  ) {\n    fileType = 'csv';\n  } else if (\n    mimeType.includes('wordprocessingml') ||\n    mimeType.includes('msword') ||\n    ['doc', 'docx'].includes(extFromName)\n  ) {\n    fileType = 'docx';\n  } else {\n    fileType = extFromName || 'unknown';\n  }\n}\n\nconst userMessage = msg.text || msg.caption || '';\n\nreturn [{\n  json: {\n    skip: false,\n    userMessage,\n    chatId,\n    username,\n    messageId,\n    hasDocument,\n    fileId,\n    fileName,\n    fileType,   // 'pdf' | 'xlsx' | 'csv' | 'docx' | 'unknown'\n    mimeType\n  }\n}];"
      },
